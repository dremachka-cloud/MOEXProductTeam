<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MOEX Team Calculator</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
:root {
  --bg: #0a0a0f;
  --card: #12121a;
  --card-alt: #16161f;
  --accent: #00d4aa;
  --accent-dim: rgba(0,212,170,0.15);
  --accent-glow: rgba(0,212,170,0.4);
  --text: #e0e0e0;
  --text-dim: #888;
  --danger: #ff4444;
  --warning: #ffaa00;
  --success: #00d4aa;
  --radius: 12px;
  --font: 'Plus Jakarta Sans', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  line-height: 1.6;
}

/* === HEADER === */
.header {
  text-align: center;
  padding: 40px 20px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.header h1 {
  font-family: var(--mono);
  font-size: 28px;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: -0.5px;
}
.header p {
  color: var(--text-dim);
  font-size: 14px;
  margin-top: 4px;
}

/* === CONTAINER === */
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 20px;
}

/* === FORM === */
#formSection {
  max-width: 680px;
  margin: 40px auto;
  transition: opacity 0.4s ease, transform 0.4s ease;
}
#formSection.hiding {
  opacity: 0;
  transform: translateY(-10px);
}

.form-group {
  margin-bottom: 20px;
  position: relative;
}
.form-group label {
  display: block;
  font-weight: 600;
  font-size: 14px;
  margin-bottom: 8px;
  color: var(--text);
}
.form-group textarea,
.form-group input {
  width: 100%;
  background: var(--card);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius);
  color: var(--text);
  font-family: var(--font);
  font-size: 15px;
  padding: 14px 16px;
  outline: none;
  transition: border-color 0.3s;
  resize: vertical;
}
.form-group textarea:focus,
.form-group input:focus {
  border-color: var(--accent);
}
.form-group textarea { min-height: 100px; }
.form-group .hint {
  font-size: 12px;
  color: var(--text-dim);
  margin-top: 4px;
}
.form-group .hint a { color: var(--accent); text-decoration: none; }
.form-group .error-msg {
  color: var(--danger);
  font-size: 12px;
  margin-top: 4px;
  display: none;
}

/* === BUTTON === */
.btn-primary {
  display: block;
  width: 100%;
  padding: 16px;
  font-family: var(--font);
  font-size: 16px;
  font-weight: 700;
  color: #0a0a0f;
  background: var(--accent);
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}
.btn-primary:hover {
  box-shadow: 0 0 30px var(--accent-glow);
  transform: translateY(-1px);
}
.btn-primary:active { transform: translateY(0); }

/* === LOADING === */
#loadingSection {
  display: none;
  text-align: center;
  padding: 80px 20px;
  animation: fadeIn 0.5s ease;
}

.spinner {
  width: 64px; height: 64px;
  margin: 0 auto 30px;
  border-radius: 50%;
  border: 3px solid rgba(255,255,255,0.06);
  border-top-color: var(--accent);
  animation: spin 1s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-status {
  font-size: 18px;
  font-weight: 600;
  color: var(--text);
  min-height: 28px;
  animation: fadeIn 0.4s ease;
}

.progress-bar-wrap {
  max-width: 400px;
  margin: 24px auto 0;
  height: 4px;
  background: rgba(255,255,255,0.06);
  border-radius: 2px;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--accent), #00f5c8);
  border-radius: 2px;
  transition: width 0.5s ease;
}

/* === DASHBOARD === */
#dashboard {
  display: none;
  padding-bottom: 60px;
  animation: fadeIn 0.6s ease;
}

.dash-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 30px 0 24px;
  justify-content: flex-end;
}
.btn-tool {
  padding: 10px 18px;
  font-family: var(--font);
  font-size: 13px;
  font-weight: 600;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  background: var(--card);
  color: var(--text);
  cursor: pointer;
  transition: all 0.2s;
}
.btn-tool:hover { border-color: var(--accent); color: var(--accent); }
.btn-tool.accent {
  background: var(--accent);
  color: #0a0a0f;
  border-color: var(--accent);
}
.btn-tool.accent:hover { box-shadow: 0 0 20px var(--accent-glow); }

/* === SECTION === */
.dash-section {
  margin-bottom: 36px;
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.5s ease;
}
.dash-section.visible {
  opacity: 1;
  transform: translateY(0);
}
.dash-section h2 {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 16px;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 10px;
}
.dash-section h2 .icon { font-size: 22px; }

/* === DESCRIPTION CARD === */
.desc-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 24px 28px;
  border-left: 4px solid var(--accent);
  font-size: 15px;
  line-height: 1.7;
  color: var(--text);
}

/* === KPI GRID === */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-top: 16px;
}
.kpi-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 24px;
  text-align: center;
  transition: transform 0.2s;
  border: 1px solid rgba(255,255,255,0.04);
}
.kpi-card:hover { transform: translateY(-2px); }
.kpi-value {
  font-family: var(--mono);
  font-size: 32px;
  font-weight: 700;
  color: var(--accent);
  line-height: 1.2;
}
.kpi-label {
  font-size: 13px;
  color: var(--text-dim);
  margin-top: 6px;
}
.kpi-sub {
  font-size: 11px;
  color: var(--text-dim);
  margin-top: 2px;
}

/* === TABLE === */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius);
  border: 1px solid rgba(255,255,255,0.06);
}
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
thead th {
  background: var(--accent);
  color: #0a0a0f;
  font-weight: 700;
  padding: 12px 14px;
  text-align: left;
  white-space: nowrap;
  font-size: 13px;
}
tbody td {
  padding: 11px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
tbody tr:nth-child(even) { background: var(--card); }
tbody tr:nth-child(odd) { background: var(--card-alt); }
tbody tr:last-child { font-weight: 700; background: rgba(0,212,170,0.08); }
tbody tr:last-child td { border-bottom: none; }

/* === BAR CHART === */
.bar-chart { margin-top: 20px; }
.bar-item {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
  font-size: 13px;
}
.bar-label {
  width: 200px;
  min-width: 200px;
  text-align: right;
  padding-right: 14px;
  color: var(--text-dim);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.bar-track {
  flex: 1;
  height: 24px;
  background: rgba(255,255,255,0.03);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}
.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), #00f5c8);
  border-radius: 4px;
  transition: width 1s ease;
  display: flex;
  align-items: center;
  padding-left: 8px;
  font-family: var(--mono);
  font-size: 11px;
  color: #0a0a0f;
  font-weight: 700;
  min-width: fit-content;
}

/* === METRICS === */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.metric-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 24px;
  border: 1px solid rgba(255,255,255,0.04);
}
.metric-name {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 4px;
}
.metric-desc {
  font-size: 12px;
  color: var(--text-dim);
  margin-bottom: 16px;
  line-height: 1.5;
}
.gauge-wrap {
  width: 140px;
  height: 80px;
  margin: 0 auto 16px;
  position: relative;
}
.gauge-bg, .gauge-fill {
  position: absolute;
  width: 140px; height: 140px;
  border-radius: 50%;
  clip-path: polygon(0 0, 100% 0, 100% 50%, 0 50%);
}
.gauge-bg {
  background: rgba(255,255,255,0.06);
}
.gauge-fill {
  background: conic-gradient(var(--warning) 0deg, var(--success) 180deg);
  transform-origin: center center;
  animation: gaugeIn 1.2s ease forwards;
  opacity: 0;
}
@keyframes gaugeIn { to { opacity: 1; } }

.metric-values {
  display: flex;
  justify-content: center;
  gap: 20px;
  font-size: 13px;
  margin-bottom: 12px;
}
.metric-threshold { color: var(--warning); }
.metric-target { color: var(--success); }
.metric-measure {
  font-size: 11px;
  color: var(--text-dim);
  line-height: 1.5;
  border-top: 1px solid rgba(255,255,255,0.06);
  padding-top: 10px;
  margin-top: 4px;
}

/* === RISKS === */
.risks-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}
.risk-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 20px;
  border: 1px solid rgba(255,255,255,0.04);
}
.risk-title {
  font-weight: 700;
  font-size: 15px;
  margin-bottom: 10px;
}
.risk-badges {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}
.badge {
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
}
.badge-high { background: rgba(255,68,68,0.2); color: var(--danger); }
.badge-medium { background: rgba(255,170,0,0.2); color: var(--warning); }
.badge-low { background: rgba(0,212,170,0.2); color: var(--success); }
.risk-mitigation {
  font-size: 13px;
  color: var(--text-dim);
  line-height: 1.5;
}

/* === RISK MATRIX === */
.risk-matrix-wrap {
  margin-top: 24px;
  display: flex;
  justify-content: center;
}
.risk-matrix {
  display: grid;
  grid-template-columns: 40px repeat(3, 80px);
  grid-template-rows: repeat(3, 60px) 30px;
  gap: 3px;
  font-size: 11px;
  text-align: center;
}
.rm-label {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  color: var(--text-dim);
  font-size: 10px;
}
.rm-label-y { writing-mode: vertical-rl; transform: rotate(180deg); }
.rm-cell {
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--mono);
  font-weight: 700;
  font-size: 12px;
  gap: 3px;
  flex-wrap: wrap;
  padding: 4px;
}
.rm-green { background: rgba(0,212,170,0.15); color: var(--success); }
.rm-yellow { background: rgba(255,170,0,0.15); color: var(--warning); }
.rm-red { background: rgba(255,68,68,0.15); color: var(--danger); }
.rm-dot {
  width: 20px; height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  color: #fff;
  font-weight: 700;
}

/* === TOAST === */
.toast {
  position: fixed;
  top: 20px;
  right: 20px;
  padding: 14px 22px;
  background: var(--card);
  border: 1px solid var(--accent);
  border-radius: 8px;
  font-size: 14px;
  color: var(--accent);
  z-index: 9999;
  animation: toastIn 0.3s ease, toastOut 0.3s ease 2.5s forwards;
  box-shadow: 0 4px 20px rgba(0,0,0,0.4);
}
@keyframes toastIn { from { opacity:0; transform:translateY(-10px); } to { opacity:1; transform:translateY(0); } }
@keyframes toastOut { from { opacity:1; } to { opacity:0; transform:translateY(-10px); } }

/* === FOOTER === */
.footer {
  text-align: center;
  padding: 30px;
  font-size: 12px;
  color: var(--text-dim);
  border-top: 1px solid rgba(255,255,255,0.04);
  margin-top: 40px;
}

/* === ERROR DISPLAY === */
#errorDisplay {
  display: none;
  max-width: 680px;
  margin: 30px auto;
  padding: 20px 24px;
  background: rgba(255,68,68,0.08);
  border: 1px solid rgba(255,68,68,0.3);
  border-radius: var(--radius);
  color: var(--danger);
  text-align: center;
}
#errorDisplay .error-text { font-size: 15px; margin-bottom: 12px; }
#errorDisplay .btn-tool { margin-top: 8px; }

@keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
@keyframes fadeInUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }

/* === RESPONSIVE === */
@media (max-width: 900px) {
  .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  .metrics-grid { grid-template-columns: 1fr; }
  .risks-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .header h1 { font-size: 22px; }
  .kpi-value { font-size: 26px; }
  .bar-label { width: 120px; min-width: 120px; font-size: 11px; }
  .dash-toolbar { justify-content: center; }
}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <h1>MOEX Team Calculator</h1>
  <p>Калькулятор продуктовых команд</p>
</div>

<!-- FORM -->
<div id="formSection" class="container">
  <div style="max-width:680px;margin:40px auto">
    <div class="form-group">
      <label>Описание задачи команды</label>
      <textarea id="taskInput" placeholder="Опишите задачу, которую должна решать ИТ команда. Например: Развивать инхаус BPM-систему, интегрировать с торговой системой и автоматизировать 10 процессов..."></textarea>
      <div class="error-msg" id="taskError">Заполните описание задачи</div>
    </div>
    <div class="form-group">
      <label>Ценность для бизнеса</label>
      <textarea id="valueInput" placeholder="Какую ценность команда принесёт организации? Например: Сокращение time-to-market, снижение операционных расходов, повышение STP..."></textarea>
      <div class="error-msg" id="valueError">Заполните ценность для бизнеса</div>
    </div>
    <div class="form-group">
      <label>API-ключ Groq</label>
      <input type="password" id="apiKeyInput" placeholder="gsk_...">
      <div class="hint">Получить бесплатно: <a href="https://console.groq.com" target="_blank">console.groq.com</a></div>
      <div class="error-msg" id="keyError">Введите API-ключ</div>
    </div>
    <button class="btn-primary" id="calcBtn" onclick="startCalculation()">Рассчитать команду</button>
  </div>
</div>

<!-- LOADING -->
<div id="loadingSection">
  <div class="spinner"></div>
  <div class="loading-status" id="statusText">Анализирую описание задачи...</div>
  <div class="progress-bar-wrap">
    <div class="progress-bar-fill" id="progressFill"></div>
  </div>
</div>

<!-- ERROR -->
<div id="errorDisplay">
  <div class="error-text" id="errorText"></div>
  <button class="btn-tool accent" onclick="resetToForm()">Попробовать снова</button>
</div>

<!-- DASHBOARD -->
<div id="dashboard" class="container"></div>

<!-- FOOTER -->
<div class="footer">Powered by AI &bull; Московская биржа &bull; 2026</div>

<script>
let lastResult = null;

// --- Restore API key ---
(function() {
  const saved = sessionStorage.getItem('groq_key');
  if (saved) document.getElementById('apiKeyInput').value = saved;
})();

// --- TOAST ---
function showToast(msg) {
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}

// --- FORMAT ---
function fmt(n) {
  return Math.round(n).toLocaleString('ru-RU');
}
function fmtMln(n) {
  return (n / 1000000).toFixed(1).replace('.', ',') + ' млн ₽';
}

// --- STATUSES ---
const statuses = [
  'Анализирую описание задачи...',
  'Определяю состав команды...',
  'Рассчитываю зарплаты по рынку Москвы 2026...',
  'Формирую метрики эффективности...',
  'Оцениваю риски...',
  'Собираю dashboard...'
];
let statusIdx = 0;
let statusInterval = null;

function startStatusAnimation() {
  statusIdx = 0;
  const el = document.getElementById('statusText');
  const fill = document.getElementById('progressFill');
  el.textContent = statuses[0];
  fill.style.width = '0%';
  statusInterval = setInterval(() => {
    statusIdx++;
    if (statusIdx < statuses.length) {
      el.style.opacity = 0;
      setTimeout(() => {
        el.textContent = statuses[statusIdx];
        el.style.opacity = 1;
      }, 200);
      fill.style.width = ((statusIdx + 1) / statuses.length * 100) + '%';
    } else {
      clearInterval(statusInterval);
    }
  }, 3000);
}
function stopStatusAnimation() {
  clearInterval(statusInterval);
  document.getElementById('progressFill').style.width = '100%';
}

// --- VALIDATION ---
function validate() {
  let ok = true;
  ['task','value','key'].forEach(id => {
    const input = document.getElementById(id === 'key' ? 'apiKeyInput' : id + 'Input');
    const err = document.getElementById(id === 'key' ? 'keyError' : id + 'Error');
    if (!input.value.trim()) { err.style.display = 'block'; ok = false; }
    else { err.style.display = 'none'; }
  });
  return ok;
}

// --- MAIN FLOW ---
async function startCalculation() {
  if (!validate()) return;

  const task = document.getElementById('taskInput').value.trim();
  const value = document.getElementById('valueInput').value.trim();
  const key = document.getElementById('apiKeyInput').value.trim();

  sessionStorage.setItem('groq_key', key);

  // Hide form
  const form = document.getElementById('formSection');
  form.classList.add('hiding');
  setTimeout(() => { form.style.display = 'none'; }, 400);

  // Show loading
  setTimeout(() => {
    document.getElementById('loadingSection').style.display = 'block';
    startStatusAnimation();
  }, 400);

  try {
    const data = await callGroqAPI(task, value, key);
    lastResult = data;
    stopStatusAnimation();
    setTimeout(() => {
      document.getElementById('loadingSection').style.display = 'none';
      renderDashboard(data);
      document.getElementById('dashboard').style.display = 'block';
    }, 600);
  } catch (err) {
    stopStatusAnimation();
    document.getElementById('loadingSection').style.display = 'none';
    showError(err.message);
  }
}

function showError(msg) {
  document.getElementById('errorText').textContent = msg;
  document.getElementById('errorDisplay').style.display = 'block';
}

function resetToForm() {
  document.getElementById('errorDisplay').style.display = 'none';
  document.getElementById('dashboard').style.display = 'none';
  document.getElementById('dashboard').innerHTML = '';
  const form = document.getElementById('formSection');
  form.style.display = 'block';
  setTimeout(() => form.classList.remove('hiding'), 50);
}

// --- API CALL ---
async function callGroqAPI(task, value, apiKey) {
  const systemPrompt = `Ты — CTO крупной финансовой организации (Московская биржа, 2400 сотрудников). Тебе дали описание задачи для ИТ-команды и ценность для бизнеса.

Ответь СТРОГО в формате JSON. Без markdown, без комментариев, без \`\`\`json. Только чистый валидный JSON.

Структура:
{
  "team_description": "Описание задач и ценностей команды на понятном бизнес-языке, 3-5 предложений",
  "team_size": <общее число людей, сумма count>,
  "roles": [
    {
      "role": "название роли на русском",
      "count": <число>,
      "seniority": "Junior|Middle|Senior|Lead",
      "salary_net": <зарплата на руки руб/мес, рыночная Москва 2026 финтех>,
      "total_cost": <salary_net / 0.87 * 1.302 * 1.2, округлить до 1000>,
      "justification": "зачем нужна эта роль, 1 предложение"
    }
  ],
  "monthly_cost": <сумма total_cost * count по всем ролям>,
  "annual_cost": <monthly_cost * 12>,
  "annual_cost_with_overhead": <annual_cost * 1.15, с учётом инфраструктуры и лицензий>,
  "metrics": [
    {
      "name": "название метрики",
      "description": "что измеряет, 1-2 предложения",
      "threshold": "пороговое минимальное значение с единицами измерения",
      "target": "целевое значение с единицами измерения",
      "measurement": "как именно измерять, 1-2 предложения"
    }
  ],
  "risks": [
    {
      "risk": "название риска",
      "probability": "Высокая|Средняя|Низкая",
      "impact": "Высокий|Средний|Низкий",
      "mitigation": "как снизить, 1-2 предложения"
    }
  ]
}

Верни ровно 3 метрики и ровно 5 рисков. Зарплаты должны соответствовать рынку Москвы 2026 для финтех/биржевой отрасли. team_size должен быть суммой count по всем ролям.`;

  const userMsg = `Задача команды:\n${task}\n\nЦенность для бизнеса:\n${value}`;

  let resp;
  try {
    resp = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + apiKey,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        model: 'llama-3.3-70b-versatile',
        max_tokens: 4000,
        temperature: 0.3,
        response_format: { type: 'json_object' },
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: userMsg }
        ]
      })
    });
  } catch (e) {
    throw new Error('Нет подключения к интернету. Проверьте сеть и попробуйте снова.');
  }

  if (resp.status === 401) throw new Error('Неверный API-ключ. Проверьте ключ на console.groq.com');
  if (resp.status === 429) throw new Error('Превышен лимит запросов Groq. Подождите минуту и попробуйте снова.');
  if (!resp.ok) throw new Error('Ошибка API (HTTP ' + resp.status + '). Попробуйте позже.');

  const json = await resp.json();
  const content = json.choices?.[0]?.message?.content;
  if (!content) throw new Error('AI вернул пустой ответ. Попробуйте переформулировать задачу.');

  try {
    const cleaned = content.replace(/```json|```/g, '').trim();
    return JSON.parse(cleaned);
  } catch (e) {
    throw new Error('AI вернул некорректный JSON. Попробуйте ещё раз.');
  }
}

// --- RENDER DASHBOARD ---
function renderDashboard(data) {
  const d = document.getElementById('dashboard');
  d.innerHTML = '';

  // Toolbar
  const toolbar = el('div', 'dash-toolbar');
  toolbar.innerHTML = `
    <button class="btn-tool accent" onclick="resetToForm()">↻ Новый расчёт</button>
    <button class="btn-tool" onclick="exportPDF()">📄 Экспорт PDF</button>
    <button class="btn-tool" onclick="copyJSON()">📋 Скопировать JSON</button>
  `;
  d.appendChild(toolbar);

  // Content wrapper for PDF export
  const content = el('div', '');
  content.id = 'dashContent';
  d.appendChild(content);

  // 1. Description
  const s1 = section('📋', 'Описание команды');
  s1.innerHTML += `<div class="desc-card">${esc(data.team_description)}</div>`;
  content.appendChild(s1);

  // 2. KPIs
  const s2 = section('📊', 'Ключевые показатели');
  const rolesCount = data.roles ? data.roles.length : 0;
  s2.innerHTML += `
    <div class="kpi-grid">
      <div class="kpi-card"><div class="kpi-value">${data.team_size}</div><div class="kpi-label">человек</div><div class="kpi-sub">размер команды</div></div>
      <div class="kpi-card"><div class="kpi-value">${fmtMln(data.monthly_cost)}</div><div class="kpi-label">в месяц</div><div class="kpi-sub">ФОТ + взносы</div></div>
      <div class="kpi-card"><div class="kpi-value">${fmtMln(data.annual_cost_with_overhead)}</div><div class="kpi-label">в год</div><div class="kpi-sub">с накладными 15%</div></div>
      <div class="kpi-card"><div class="kpi-value">${rolesCount}</div><div class="kpi-label">ролей</div><div class="kpi-sub">уникальных</div></div>
    </div>`;
  content.appendChild(s2);

  // 3. Roles table
  const s3 = section('👥', 'Состав и стоимость команды');
  let totalCost = 0;
  let rows = '';
  (data.roles || []).forEach((r, i) => {
    const lineCost = r.total_cost * r.count;
    totalCost += lineCost;
    rows += `<tr>
      <td>${i+1}</td>
      <td>${esc(r.role)}</td>
      <td>${esc(r.seniority)}</td>
      <td style="text-align:center">${r.count}</td>
      <td style="font-family:var(--mono)">${fmt(r.salary_net)} ₽</td>
      <td style="font-family:var(--mono)">${fmt(lineCost)} ₽</td>
      <td style="font-size:12px;color:var(--text-dim)">${esc(r.justification)}</td>
    </tr>`;
  });
  rows += `<tr><td colspan="5" style="text-align:right;font-weight:700">ИТОГО в месяц:</td><td style="font-family:var(--mono);font-weight:700;color:var(--accent)">${fmt(totalCost)} ₽</td><td></td></tr>`;

  s3.innerHTML += `<div class="table-wrap"><table>
    <thead><tr><th>№</th><th>Роль</th><th>Грейд</th><th>Кол-во</th><th>На руки ₽/мес</th><th>Стоимость ₽/мес</th><th>Обоснование</th></tr></thead>
    <tbody>${rows}</tbody>
  </table></div>`;

  // Bar chart
  let barHtml = '<div class="bar-chart">';
  (data.roles || []).forEach(r => {
    const lineCost = r.total_cost * r.count;
    const pct = totalCost > 0 ? (lineCost / totalCost * 100) : 0;
    barHtml += `<div class="bar-item">
      <div class="bar-label">${esc(r.role)} ×${r.count}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${pct}%">${pct.toFixed(1)}%</div></div>
    </div>`;
  });
  barHtml += '</div>';
  s3.innerHTML += barHtml;
  content.appendChild(s3);

  // 4. Metrics
  const s4 = section('🎯', 'Метрики эффективности');
  let metricsHtml = '<div class="metrics-grid">';
  (data.metrics || []).forEach(m => {
    metricsHtml += `<div class="metric-card">
      <div class="metric-name">${esc(m.name)}</div>
      <div class="metric-desc">${esc(m.description)}</div>
      <div class="gauge-wrap">
        <div class="gauge-bg"></div>
        <div class="gauge-fill"></div>
      </div>
      <div class="metric-values">
        <span class="metric-threshold">Порог: ${esc(m.threshold)}</span>
        <span class="metric-target">Цель: ${esc(m.target)}</span>
      </div>
      <div class="metric-measure">${esc(m.measurement)}</div>
    </div>`;
  });
  metricsHtml += '</div>';
  s4.innerHTML += metricsHtml;
  content.appendChild(s4);

  // 5. Risks
  const s5 = section('⚠️', 'Реестр рисков');
  let risksHtml = '<div class="risks-grid">';
  (data.risks || []).forEach((r, i) => {
    risksHtml += `<div class="risk-card">
      <div class="risk-title">${i+1}. ${esc(r.risk)}</div>
      <div class="risk-badges">
        <span class="badge ${badgeClass(r.probability)}">Вероятность: ${esc(r.probability)}</span>
        <span class="badge ${badgeClass(r.impact)}">Влияние: ${esc(r.impact)}</span>
      </div>
      <div class="risk-mitigation">${esc(r.mitigation)}</div>
    </div>`;
  });
  risksHtml += '</div>';
  s5.innerHTML += risksHtml;

  // Risk matrix
  const matrixColors = [
    ['rm-yellow','rm-red','rm-red'],
    ['rm-green','rm-yellow','rm-red'],
    ['rm-green','rm-green','rm-yellow']
  ];
  const probMap = {'Высокая':0,'Средняя':1,'Низкая':2};
  const impMap = {'Низкий':0,'Средний':1,'Высокий':2};

  let cells = Array.from({length:3}, () => Array.from({length:3}, () => []));
  (data.risks || []).forEach((r, i) => {
    const py = probMap[r.probability] ?? 1;
    const ix = impMap[r.impact] ?? 1;
    cells[py][ix].push(i + 1);
  });

  let matrixHtml = '<div class="risk-matrix-wrap"><div class="risk-matrix">';
  // Row 0: header spacer + impact labels
  matrixHtml += '<div></div>';
  ['Низкое','Среднее','Высокое'].forEach(l => { matrixHtml += `<div class="rm-label">${l}</div>`; });
  // Rows 1-3
  ['Высокая','Средняя','Низкая'].forEach((label, row) => {
    matrixHtml += `<div class="rm-label rm-label-y">${label}</div>`;
    for (let col = 0; col < 3; col++) {
      const dots = cells[row][col].map(n => `<span class="rm-dot" style="background:rgba(255,255,255,0.2)">${n}</span>`).join('');
      matrixHtml += `<div class="rm-cell ${matrixColors[row][col]}">${dots}</div>`;
    }
  });
  // Bottom labels
  matrixHtml += '<div></div><div class="rm-label" style="grid-column:span 3;font-size:11px">Влияние →</div>';
  matrixHtml += '</div></div>';
  s5.innerHTML += matrixHtml;
  content.appendChild(s5);

  // Animate sections
  setTimeout(() => {
    document.querySelectorAll('.dash-section').forEach((s, i) => {
      setTimeout(() => s.classList.add('visible'), i * 200);
    });
  }, 100);
}

// --- HELPERS ---
function el(tag, cls) {
  const e = document.createElement(tag);
  if (cls) e.className = cls;
  return e;
}
function section(icon, title) {
  const s = document.createElement('div');
  s.className = 'dash-section';
  s.innerHTML = `<h2><span class="icon">${icon}</span>${title}</h2>`;
  return s;
}
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function badgeClass(level) {
  const l = (level||'').toLowerCase();
  if (l.includes('высок')) return 'badge-high';
  if (l.includes('средн')) return 'badge-medium';
  return 'badge-low';
}

// --- EXPORT PDF ---
async function exportPDF() {
  const btn = event.target;
  btn.textContent = '⏳ Генерация...';
  btn.disabled = true;
  const el = document.getElementById('dashContent');
  const opt = {
    margin: 10,
    filename: `MOEX_Team_${new Date().toISOString().slice(0,10)}.pdf`,
    image: { type: 'jpeg', quality: 0.95 },
    html2canvas: { scale: 2, backgroundColor: '#0a0a0f' },
    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
  };
  try {
    await html2pdf().set(opt).from(el).save();
  } catch(e) { showToast('Ошибка генерации PDF'); }
  btn.textContent = '📄 Экспорт PDF';
  btn.disabled = false;
}

// --- COPY JSON ---
function copyJSON() {
  if (!lastResult) { showToast('Нет данных'); return; }
  navigator.clipboard.writeText(JSON.stringify(lastResult, null, 2))
    .then(() => showToast('JSON скопирован в буфер'))
    .catch(() => showToast('Не удалось скопировать'));
}
</script>
</body>
</html>
